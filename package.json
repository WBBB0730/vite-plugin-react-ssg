{
  "name": "vite-plugin-react-ssg",
  "type": "module",
  "version": "0.0.0",
  "description": "A build-time prerendering plugin that generates static HTML for traditional Vite React SPAs.",
  "author": "wbbb",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./config": "./dist/config.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.2",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.2.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bumpp": "^11.0.1",
    "react-router": "^7.13.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
