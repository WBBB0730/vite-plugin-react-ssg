{
  "name": "vite-plugin-react-ssg",
  "type": "module",
  "version": "0.0.1",
  "description": "A build-time prerendering plugin that generates static HTML for traditional Vite React SPAs.",
  "author": "WBBB",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WBBB0730/vite-plugin-react-ssg.git"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./config": "./dist/config.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "tsx ./scripts/play.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit --project playgrounds/tsconfig.json && tsc --noEmit --project scripts/tsconfig.json",
    "prepare-release": "node ./scripts/prepare-npm-release.mjs",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=16.8",
    "react-dom": ">=16.8",
    "react-router": "^6.4.0 || ^7.0.0",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.2.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bumpp": "^11.0.1",
    "react-router": "^7.13.2",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
